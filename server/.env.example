# Redis 任务队列（与 littlebits 相同变量名，可直接复用 backend/.env）
REDIS_URL=redis://127.0.0.1:6379/0
TRIPOSPLAT_REDIS_QUEUE=triposplat:queue
TRIPOSPLAT_REDIS_JOB_PREFIX=triposplat:job:
TRIPOSPLAT_JOB_TTL_SECONDS=604800

# 七牛（与 littlebits backend/.env 一致）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_CDN_DOMAIN=
QINIU_TRIPOSPLAT_PREFIX=triposplat

# 推理
TRIPOSPLAT_DEVICE=cuda
TRIPOSPLAT_NUM_GAUSSIANS=32768
TRIPOSPLAT_SEED=42
TRIPOSPLAT_STEPS=20
TRIPOSPLAT_GUIDANCE_SCALE=3.0
TRIPOSPLAT_SHIFT=3.0
